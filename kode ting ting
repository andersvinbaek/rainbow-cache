#include <Wire.h>
#include "rgb_lcd.h"
#include <SoftwareSerial.h>
#include <DFRobotDFPlayerMini.h>

// LCD
rgb_lcd lcd;

// DFPlayer
SoftwareSerial mySerial(8, 9);
DFRobotDFPlayerMini player;

// Sensor
const int sensorPin = A0;

// Calibration (CHANGE THESE)
int dryValue = 700;
int wetValue = 400;

// Track last state (avoid spam playing)
int lastState = -1;

void setup() {
  // LCD
  lcd.begin(16, 2);
  lcd.setRGB(0, 255, 0);
  lcd.print("Starter...");
  
  // Serial for DFPlayer
  mySerial.begin(9600);
  
  if (!player.begin(mySerial)) {
    lcd.clear();
    lcd.print("DFPlayer fejl");
    while (true);
  }

  player.volume(20); // 0–30

  delay(2000);
  lcd.clear();
}

void loop() {
  int sensorValue = analogRead(sensorPin);

  int moisturePercent = map(sensorValue, dryValue, wetValue, 0, 100);
  moisturePercent = constrain(moisturePercent, 0, 100);

  lcd.setCursor(0, 0);
  lcd.print("Val:");
  lcd.print(sensorValue);
  lcd.print("   ");

  lcd.setCursor(9, 0);
  lcd.print(moisturePercent);
  lcd.print("% ");

  int currentState;

  lcd.setCursor(0, 1);

  if (moisturePercent < 30) {
    lcd.print("Toer jord       ");
    lcd.setRGB(255, 0, 0);
    currentState = 0;
  } 
  else if (moisturePercent < 70) {
    lcd.print("Fugtig jord     ");
    lcd.setRGB(255, 165, 0);
    currentState = 1;
  } 
  else {
    lcd.print("Vaadt jord       ");
    lcd.setRGB(0, 0, 255);
    currentState = 2;
  }

  // 🔊 Play sound ONLY when state changes
  if (currentState != lastState) {
    if (currentState == 0) {
      player.play(1); // 0001.mp3
    } 
    if (currentState == 2) {
      player.play(2);
    }
   

    lastState = currentState;
  }

  delay(1000);
}
